{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "test:job-tier": "tsx ./scripts/test-job-tier-flows.ts",
    "test:notifications": "tsx ./scripts/test-notifications.ts",
    "test:weekly-digest": "tsx ./scripts/test-weekly-digest.ts",
    "test:digest-slot": "tsx ./scripts/test-digest-slot.ts",
    "test:growth-plan": "tsx ./scripts/test-growth-plan.ts",
    "test:career-constellation": "tsx ./scripts/test-career-constellation.ts",
    "test:fast-track": "tsx ./scripts/test-fast-track.ts",
    "test:whatsapp": "tsx ./scripts/test-whatsapp.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google-cloud/storage": "^7.19.0",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^10.53.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.2",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.6.2",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.12.3",
    "stripe": "^22.1.0",
    "ulid": "^3.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-signature": "^1.1.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
